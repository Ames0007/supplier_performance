# ============================================================
# UM6P Supplier Performance Management Platform — environment
# Copy to `.env.local` for local development.
# ============================================================

# --- Application ---
NEXT_PUBLIC_APP_NAME="UM6P SPM"
NODE_ENV=development

# --- Runtime ---
# Frontend dev/prod port is fixed to 3004 (see package.json scripts).

# --- Public Development Mode (TEMPORARY auth bypass — dev/demo ONLY) ---
# When enabled, the login requirement is bypassed and every request acts as a
# "Development Administrator" (SUPER_ADMIN) so all screens are browsable without
# signing in. A red/amber banner is shown on every page. This does NOT remove
# Supabase Auth, Entra, the middleware, RBAC, or audit — it only skips login.
#
# ENABLED when NODE_ENV=development (automatic with `npm run dev`) OR when the
# flag below is "true". To run a demo on Vercel Preview, set:
#   NEXT_PUBLIC_PUBLIC_DEMO=true   (then REDEPLOY — it is a NEXT_PUBLIC_ build-time value)
# Leave it UNSET/empty in Production to keep real authentication in force.
# Full detail + how to disable: docs/PUBLIC_DEVELOPMENT_MODE.md
NEXT_PUBLIC_PUBLIC_DEMO=

# --- Authentication & Data (REQUIRED for the auth foundation to function) ---
# Microsoft Entra ID SSO is brokered by Supabase Auth (OAuth "azure" provider).
# Configure the Azure/Entra provider in the Supabase dashboard, then set:
#
#   NEXT_PUBLIC_SUPABASE_URL       — your Supabase project URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  — the anon (public) key; RLS-gated
#   SUPABASE_SERVICE_ROLE_KEY      — server-only; NEVER exposed to the browser
#
# FAIL-CLOSED: when these are absent the app grants NO session (every request is
# unauthenticated and redirected to /sign-in). There is no demo/admin fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Microsoft Entra (configured in the Supabase Azure provider) ---
# These are set in Supabase Auth (not read directly by the app); listed for ops.
# AZURE_AD_CLIENT_ID=
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_SECRET=
