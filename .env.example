# ============================================================
# UM6P Supplier Performance Management Platform — environment
# Copy to `.env.local` for local development.
# ============================================================

# --- Application ---
NEXT_PUBLIC_APP_NAME="UM6P SPM"
NODE_ENV=development

# --- Runtime ---
# Frontend dev/prod port is fixed to 3004 (see package.json scripts).

# --- Authentication & Data (wired at P1 completion) ---
# The blueprint targets Microsoft Entra ID (SSO) brokered via Supabase.
# Phase 1 ships the auth/RBAC FOUNDATION behind repository interfaces with an
# in-memory implementation, so these are not required to run the foundation.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_TENANT_ID=
